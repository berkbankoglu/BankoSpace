{
  "productName": "BankoSpace",
  "version": "4.1.2",
  "identifier": "com.berkbankoglu.bankospace",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app"],
    "publisher": "Berk Bankoglu",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "app": {
    "windows": [
      {
        "title": "BankoSpace",
        "label": "main",
        "width": 1400,
        "height": 800,
        "minWidth": 1200,
        "minHeight": 600,
        "resizable": true,
        "maximized": true,
        "fullscreen": false,
        "decorations": false,
        "url": "index.html"
      },
      {
        "title": "Kana Practice",
        "label": "kana-popup",
        "width": 420,
        "height": 750,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "url": "kana.html",
        "center": true,
        "skipTaskbar": true
      },
      {
        "title": "Timer",
        "label": "timer-popup",
        "width": 260,
        "height": 310,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "url": "timer.html",
        "center": true,
        "skipTaskbar": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://accounts.google.com https://*.googleapis.com https://*.firebaseapp.com https://*.firebaseio.com https://*.cloudfunctions.net https://feeds.finance.yahoo.com https://finance.yahoo.com https://news.google.com https://*.google.com https://query1.finance.yahoo.com https://query2.finance.yahoo.com https://api.anthropic.com https://*.tradingview.com https://s3.tradingview.com https://translate.google.com https://translate.googleapis.com https://*.supabase.co wss://*.supabase.co https://feeds.reuters.com https://*.reuters.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://s3.tradingview.com https://*.tradingview.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com https://*.tradingview.com; media-src 'self' https://translate.google.com https://translate.googleapis.com; frame-src https://accounts.google.com https://*.firebaseapp.com https://*.tradingview.com",
      "capabilities": [
        {
          "identifier": "main-capability",
          "description": "Main app capabilities",
          "windows": ["main", "timer-popup", "kana-popup"],
          "permissions": [
            "dialog:default",
            "dialog:allow-save",
            "dialog:allow-open",
            "fs:default",
            "fs:allow-read-text-file",
            "fs:allow-write-text-file",
            "fs:allow-read-file",
            "fs:allow-read-dir",
            "notification:default",
            "core:window:allow-create",
            "core:window:allow-close",
            "core:window:allow-minimize",
            "core:window:allow-maximize",
            "core:window:allow-unmaximize",
            "core:window:allow-is-maximized",
            "core:window:allow-is-fullscreen",
            "core:window:allow-set-fullscreen",
            "core:window:allow-set-always-on-top",
            "core:window:allow-start-dragging",
            "core:webview:allow-create-webview-window",
            "core:webview:allow-create-webview",
            "core:webview:allow-webview-close",
            "core:webview:allow-webview-hide",
            "core:webview:allow-webview-show",
            "core:webview:allow-set-webview-position",
            "core:webview:allow-set-webview-size",
            "core:webview:allow-set-webview-focus",
            "core:webview:allow-get-all-webviews",
            "core:window:allow-destroy",
            "core:window:allow-show",
            "core:window:allow-hide",
            "core:window:allow-is-visible",
            "core:window:allow-set-focus",
            "core:window:allow-set-size",
            "shell:allow-open",
            "deep-link:default"
          ]
        }
      ]
    }
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["bankospace"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/berkbankoglu/BankoSpace/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE2OUVFREUwMzFFQkZFMzcKUldRMy91c3g0TzJlcHRHYWgrZ2w1K0cxN1d1U2dlZ0FsSjhFM25hSzN4OHNwd25WTWFsVXNUcnoK"
    }
  }
}
